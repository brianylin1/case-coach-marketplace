# Copy to .env and fill in. Secrets are gitignored.

# Database — Neon pooled connection string in prod; local Postgres for dev.
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Signed-cookie session secret (any long random string).
SESSION_SECRET="change-me"

# Email (Resend). Only sends when VERCEL_ENV=production or EMAIL_FORCE_SEND=1.
RESEND_API_KEY=""
EMAIL_FROM="Down to Case <bookings@downtocase.com>"
EMAIL_FROM_ADDRESS="bookings@downtocase.com"

# ---- Stripe payments (Phase 1, Option B: hold funds until after session) ----
# Master switch. Leave false until the live test-mode E2E passes.
PAYMENTS_ENABLED="false"
# Stripe secret key: sk_test_… in test mode, sk_live_… in production.
STRIPE_SECRET_KEY=""
# Signing secret for the /api/webhooks/stripe endpoint (whsec_…).
STRIPE_WEBHOOK_SECRET=""
# Platform take rate in basis points (1500 = 15%).
PLATFORM_FEE_BPS="1500"
# Hours after a session ends before held funds release to the coach.
PAYOUT_HOLD_HOURS="24"
# Shared secret protecting POST /api/cron/release-payouts (Vercel Cron sends it).
CRON_SECRET=""
