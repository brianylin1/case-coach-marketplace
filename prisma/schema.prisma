// CaseCoach — calendar-first booking marketplace.
// Coaches paint a recurring weekly availability grid (AvailabilityBlock rows).
// Bookable 60-min sessions are generated on the fly (see lib/availability.ts);
// a Booking stores its own concrete UTC start time. Lists are JSON-string
// columns and enums are plain strings validated in app code. See AGENTS.md.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  targetFirms String    @default("[]")
  focusAreas  String    @default("[]")
  timeline    String?
  goal        String?
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Coach {
  id           Int                 @id @default(autoincrement())
  name         String
  email        String              @unique
  firm         String
  title        String
  yearsAtFirm  Int                 @default(0)
  headline     String?
  bio          String
  focusAreas   String              @default("[]")
  hourlyRate   Int                 @default(0)
  availability String?
  linkedinUrl  String?
  // Trust/positioning — all optional, with student-facing fallbacks when unset
  // (see lib/constants.ts for the curated keys). bestFor: single BEST_FOR key;
  // casesCoached: CASES_COACHED range bucket; firmStatus: "current" | "former"
  // at `firm` (null = unstated; we never guess). photoUrl: external image URL
  // shown in place of the initials avatar (display-only; no upload/storage).
  bestFor       String?
  casesCoached  String?
  firmStatus    String?
  photoUrl      String?
  // Coach-provided meeting room. A coach is bookable only once meetingUrl +
  // meetingPlatform are set (no auto-generated rooms).
  meetingPlatform     String?        // "teams" | "zoom" | "meet" | "other"
  meetingUrl          String?
  meetingId           String?
  meetingPasscode     String?
  meetingInstructions String?
  timezone     String              @default("UTC") // IANA tz; availability is authored as wall-clock time in this zone
  // Stripe Connect (Express). Set once a coach onboards for payouts. A coach
  // with hourlyRate > 0 is bookable only when stripePayoutsEnabled is true
  // (pro bono coaches never need Stripe). Cached from the account.updated webhook.
  stripeAccountId      String?
  stripePayoutsEnabled Boolean             @default(false)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  blocks       AvailabilityBlock[]
  bookings     Booking[]
}

// One contiguous green run in a day column of the coach's weekly grid.
// weekday: 0 = Mon … 6 = Sun. start/endMinute: minutes from midnight as
// WALL-CLOCK time in the coach's timezone, end exclusive — a 9am–12pm block is
// 540 … 720. Concrete UTC session starts are generated per-date (DST-correct).
model AvailabilityBlock {
  id          Int   @id @default(autoincrement())
  coach       Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     Int
  weekday     Int
  startMinute Int
  endMinute   Int

  @@index([coachId])
}

// A confirmed booking of a generated 60-min session. The unique (coachId,
// startTime) is the hard guarantee against double-booking. Payment fields live
// here so a real provider (Stripe) can slot in behind lib/payments.ts later.
model Booking {
  id            Int      @id @default(autoincrement())
  coach         Coach    @relation(fields: [coachId], references: [id])
  coachId       Int
  student       Student  @relation(fields: [studentId], references: [id])
  studentId     Int
  startTime     DateTime
  durationMins  Int      @default(60)
  focusArea     String?
  pricePaid     Int      @default(0)
  paymentStatus String   @default("SIMULATED")
  paymentRef    String?
  status        String   @default("CONFIRMED") // PENDING_PAYMENT | CONFIRMED | CANCELLED | EXPIRED
  // Coach meeting details, snapshotted at booking time so the card/email/ICS
  // stay consistent even if the coach later edits their room.
  meetingPlatform     String?
  meetingUrl          String?
  meetingId           String?
  meetingPasscode     String?
  meetingInstructions String?
  emailStatus   String   @default("PENDING") // PENDING | SENT | SIMULATED | FAILED
  // ---- Stripe (Phase 1, Option B: hold funds on platform until after session)
  // For a paid booking: a PENDING_PAYMENT row holds the slot while the student
  // pays via Checkout; the charge settles to the platform; coachShareCents is
  // transferred to the coach after the session (payoutReleaseAfter).
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeChargeId          String? // set on payment success; source_transaction for the payout
  coachStripeAccountId    String? // snapshot of the coach's connected account
  amountChargedCents      Int?
  platformFeeCents        Int?
  coachShareCents         Int?
  currency                String    @default("usd")
  payoutStatus            String    @default("NONE") // NONE | HELD | RELEASED | FAILED | SKIPPED
  payoutReleaseAfter      DateTime?
  stripeTransferId        String?
  payoutReleasedAt        DateTime?
  createdAt     DateTime @default(now())

  @@unique([coachId, startTime])
  @@index([studentId])
  @@index([payoutStatus, payoutReleaseAfter])
}
