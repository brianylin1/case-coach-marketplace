// CaseCoach — calendar-first booking marketplace.
// Coaches paint a recurring weekly availability grid (AvailabilityBlock rows).
// Bookable 60-min sessions are generated on the fly (see lib/availability.ts);
// a Booking stores its own concrete UTC start time. Lists are JSON-string
// columns and enums are plain strings validated in app code. See AGENTS.md.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  targetFirms String    @default("[]")
  focusAreas  String    @default("[]")
  timeline    String?
  goal        String?
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Coach {
  id           Int                 @id @default(autoincrement())
  name         String
  email        String              @unique
  firm         String
  title        String
  yearsAtFirm  Int                 @default(0)
  headline     String?
  bio          String
  focusAreas   String              @default("[]")
  hourlyRate   Int                 @default(0)
  availability String?
  linkedinUrl  String?
  timezone     String              @default("UTC") // IANA tz; UTC for now
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  blocks       AvailabilityBlock[]
  bookings     Booking[]
}

// One contiguous green run in a day column of the coach's weekly grid.
// weekday: 0 = Mon … 6 = Sun. start/endMinute: minutes from midnight (UTC for
// now), end exclusive — a 9am–12pm block is 540 … 720.
model AvailabilityBlock {
  id          Int   @id @default(autoincrement())
  coach       Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachId     Int
  weekday     Int
  startMinute Int
  endMinute   Int

  @@index([coachId])
}

// A confirmed booking of a generated 60-min session. The unique (coachId,
// startTime) is the hard guarantee against double-booking. Payment fields live
// here so a real provider (Stripe) can slot in behind lib/payments.ts later.
model Booking {
  id            Int      @id @default(autoincrement())
  coach         Coach    @relation(fields: [coachId], references: [id])
  coachId       Int
  student       Student  @relation(fields: [studentId], references: [id])
  studentId     Int
  startTime     DateTime
  durationMins  Int      @default(60)
  focusArea     String?
  pricePaid     Int      @default(0)
  paymentStatus String   @default("SIMULATED")
  paymentRef    String?
  status        String   @default("CONFIRMED")
  createdAt     DateTime @default(now())

  @@unique([coachId, startTime])
  @@index([studentId])
}
